# Signal AI environment — docs/11 §1. Values live in Vercel/Supabase/GH secret
# stores, never in the repo. Leave everything unset to run the prototype in
# demo mode (fixture data, deterministic AI).

# Supabase (RLS-scoped client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# server only (routes/edge/scripts) — CI greps against client leaks
SUPABASE_SERVICE_ROLE_KEY=

# Google: Supabase Auth provider + Gmail OAuth (one GCP project, docs/11 §2.2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# LLMs (free tiers; router falls back Gemini → Groq → demo, docs/06 §1)
GEMINI_API_KEY=
GROQ_API_KEY=

# Product/notification email (digests, invites, alerts)
RESEND_API_KEY=

# Machine-route auth: pg_cron → edge fns, /api/cron/*, /api/ingest/batch, GH Actions
CRON_SECRET=

# RB2B webhook HMAC (shown once in Settings)
RB2B_WEBHOOK_SECRET=

# Stripe (M8)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Telemetry (PII scrubbing on)
NEXT_PUBLIC_POSTHOG_KEY=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Pixels, OAuth redirects, email links — per environment
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Seed-corpus script extras (optional)
PRODUCTHUNT_TOKEN=
GITHUB_TOKEN=
